# Optional: required when TELODOCS_DOCS_AUTH or TELODOCS_MCP_AUTH is "gated"
TELODOCS_API_KEY=change-me-to-a-long-random-string

# Access control (default: open)
TELODOCS_DOCS_AUTH=open
TELODOCS_MCP_AUTH=open

# Server
PORT=3000

# Content
TELODOCS_DOCS_DIR=./docs
TELODOCS_MCP_PATH=/mcp
# TELODOCS_SUPPORTED_EXTENSIONS=.md,.mdx,.txt,.rst

# Optional
# NODE_ENV=development
