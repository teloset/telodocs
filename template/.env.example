# Default dev key (written to .env on scaffold). Change before enabling gated auth in production.
TELODOCS_API_KEY=i-love-coding-agents

# Access control (default: open)
TELODOCS_DOCS_AUTH=open
TELODOCS_MCP_AUTH=open

# Server
PORT=3000

# Content
TELODOCS_DOCS_DIR=./docs
TELODOCS_MCP_PATH=/mcp
# TELODOCS_SUPPORTED_EXTENSIONS=.md,.mdx,.txt,.rst

# Optional
# NODE_ENV=development
