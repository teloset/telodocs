{
  "name": "@teloset/telodocs",
  "version": "0.1.0",
  "description": "Scaffold a docs repo that serves as a remote MCP server with a minimal rendered docs site",
  "author": "Sofonias <sofonias@teloset.com>",
  "homepage": "https://github.com/teloset/telodocs#readme",
  "bugs": {
    "url": "https://github.com/teloset/telodocs/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "documentation",
    "claude-code",
    "cursor",
    "codex"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teloset/telodocs.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "telodocs": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
