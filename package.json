{
  "name": "telodocs",
  "version": "0.4.4",
  "description": "Documentation MCP server and docs site — content in docs/, telodocs runs the rest",
  "author": "Sofonias <sofonias@teloset.com>",
  "homepage": "https://github.com/teloset/telodocs#readme",
  "bugs": {
    "url": "https://github.com/teloset/telodocs/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "documentation",
    "claude-code",
    "cursor",
    "codex"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teloset/telodocs.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "telodocs": "dist/cli/index.js"
  },
  "files": [
    "README.md",
    "LICENSE",
    "dist",
    "template"
  ],
  "scripts": {
    "build": "npm run build:web && npm run build:server",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "dev": "tsx src/cli/index.ts",
    "check-types": "tsc --noEmit && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@vscode/ripgrep": "^1.15.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commander": "^13.1.0",
    "cookie-parser": "^1.4.7",
    "fast-glob": "^3.3.3",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.24.0",
    "marked": "^15.0.12",
    "marked-gfm-heading-id": "^4.1.4",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hotkeys-hook": "^5.3.3",
    "react-router-dom": "^7.18.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.8.3",
    "vite": "^6.4.3",
    "vitest": "^3.1.2"
  }
}
